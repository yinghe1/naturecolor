    "id": "a7662569-feeb-4712-80ef-b267eebea87c",
    "name": "natureRed",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background-color: #fffbf0;\n            margin: 0;\n        }\n        .text {\n            font-family: 'Arial', sans-serif;\n            font-size: 100px;\n            font-weight: bold;\n            text-transform: uppercase;\n            letter-spacing: 10px;\n            text-shadow: 3px 3px #aaa;\n            display: flex;\n        }\n        .text span {\n            animation: color-change 4s infinite;\n            display: inline-block;\n            padding: 0 10px;\n        }\n        .text span:nth-child(1) { color: #ec4a53; }\n        .text span:nth-child(2) { color: #ee7d6a; }\n        .text span:nth-child(3) { color: #ffa7af; }\n        .text span:nth-child(4) { color: #620013; }\n        .text span:nth-child(5) { color: #f85700; }\n        .text span:nth-child(6) { color: #d25700; }\n\n        @keyframes color-change {\n            0%   { transform: scale(1) rotate(0deg); }\n            25%  { transform: scale(1.2) rotate(15deg); }\n            50%  { transform: scale(1) rotate(0deg); }\n            75%  { transform: scale(1.2) rotate(-15deg); }\n            100% { transform: scale(1) rotate(0deg); }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"text\">\n        <span>N</span>\n        <span>A</span>\n        <span>T</span>\n        <span>U</span>\n        <span>R</span>\n        <span>E</span>\n    </div>\n</body>\n</html>",
    "instruction": "create a sample text NATURE using different shades of nature red, make it stylish fun",
    "createdAt": "2026-04-02T02:17:55.401Z"
  },
