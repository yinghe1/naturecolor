    "id": "74fafeff-54c3-427e-838b-b3d21ede00cb",
    "name": "natureBlue",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background-color: #f0f8ff;\n            margin: 0;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n        .text-container {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n        .letter {\n            font-size: 5rem;\n            font-weight: bold;\n            padding: 0 10px;\n            transition: transform 0.3s;\n        }\n        .letter:hover {\n            transform: scale(1.2);\n        }\n        .n { color: #6b99e0; } /* sunsetblue */\n        .a { color: #4f96da; } /* sunnyblue */\n        .t { color: #4598aa; } /* swisslakeblue */\n        .u { color: #06b6cc; } /* brienzlakeblue */\n        .r { color: #9a9fd1; } /* sunsetpurple */\n        .e { color: #0136ed; } /* bluebellblue */\n    </style>\n</head>\n<body>\n    <div class=\"text-container\">\n        <span class=\"letter n\">N</span>\n        <span class=\"letter a\">A</span>\n        <span class=\"letter t\">T</span>\n        <span class=\"letter u\">U</span>\n        <span class=\"letter r\">R</span>\n        <span class=\"letter e\">E</span>\n    </div>\n</body>\n</html>",
    "instruction": "create a sample text NATURE using different shades of nature blue, make it stylish fun",
    "createdAt": "2026-04-02T02:19:06.885Z"
  }
