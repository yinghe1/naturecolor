{
  "name": "naturecolor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Extract colors from nature images and generate design systems",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "npm run dev --prefix client",
    "install:all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^10.0.0"
  }
}
